<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements. Inert unless the
  build is actually codesigned (CSC_LINK/CSC_KEY_PASSWORD set) -- an unsigned
  `npm run pack`/`electron-builder --dir` build ignores entitlements
  entirely, so this file is a signing-ready stub, never a requirement.

  Why each entry: the app spawns real OS child processes (shnkitd, the
  gateway binary, and -- with the Java trio bundled -- a jlink'd JRE running
  the HAPI validator/data-server/br-provider). The JVM needs JIT + unsigned
  executable memory, and its own dylibs/native libs are not signed by us, so
  library validation must be disabled for them to load under a hardened
  runtime. No sandbox entitlement: the app is not (and does not need to be)
  Mac App Store sandboxed.
-->
<plist version="1.0">
  <dict>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
  </dict>
</plist>
